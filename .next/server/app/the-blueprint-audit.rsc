ation roadmap"}]]}],["$","div","3",{"className":"deliverable-item mb-2","children":[["$","svg",null,{"viewBox":"0 0 16 16","fill":"none","children":[["$","circle",null,{"cx":"8","cy":"8","r":"7","stroke":"#957DAD","strokeWidth":"1.2"}],["$","path",null,{"d":"M5 8l2 2 4-4","stroke":"#957DAD","strokeWidth":"1.2","strokeLinecap":"round","strokeLinejoin":"round"}]]}],["$","span",null,{"style":{"fontSize":13,"color":"var(--text-2)"},"children":"Delivered within 5 business days"}]]}]]}],["$","$L6",null,{"href":"/the-blueprint-audit/apply","className":"btn btn-primary btn-lg btn-arrow","style":{"width":"100%","justifyContent":"center"},"children":"Apply to Book Your Blueprint"}],["$","div",null,{"className":"blueprint-credit-note","children":[["$","svg",null,{"viewBox":"0 0 16 16","fill":"none","children":[["$","circle",null,{"cx":"8","cy":"8","r":"7","stroke":"currentColor","strokeWidth":"1.2"}],["$","path",null,{"d":"M8 5v4M8 11v0.5","stroke":"currentColor","strokeWidth":"1.2","strokeLinecap":"round"}]]}],["$","span",null,{"children":"If you proceed with implementation within 30 days, the full $500 Blueprint fee is credited toward your project. No questions asked."}]]}],["$","p",null,{"style":{"textAlign":"center","fontSize":12,"color":"var(--text-3)","marginTop":"var(--space-3)"},"children":[["$","br",null,{}],"Not all applications are accepted."]}]]}]
